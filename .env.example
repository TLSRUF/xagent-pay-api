# XAgent Pay API 환경변수 설정 예시
# 이 파일을 복사해서 .env 파일을 생성하고 실제 값을 입력하세요

# XRPL 테스트넷 계정 정보
SENDER_ADDRESS=테스트넷_XRP_주소를_여기에_입력하세요
SENDER_SECRET=시크릿_키를_여기에_입력하세요

# 수수료 수신 계정 (일반적으로 발신자와 동일)
FEE_ACCOUNT=수수료_받을_주소를_여기에_입력하세요

# XRPL 테스트넷 노드 주소
XRPL_NODE=wss://s.altnet.rippletest.net:51233

# API Keys (콤마로 구분)
# 예: API_KEYS=key1,key2,key3
API_KEYS=test_key_123456,prod_key_789012,demo_key_345678

# Rate Limiting (월 최대 요청 수 per API key)
MONTHLY_REQUEST_LIMIT=100

# x402 결제 설정
# JWT 서명 키 (프로덕션에서는 반드시 변경하세요)
JWT_SECRET=강력한_비밀_키를_여기에_입력하세요

# x402 결제 금액 (XRP 단위)
X402_PAYMENT_AMOUNT=0.1

# x402 수수료 수신 주소
X402_FEE_ADDRESS=수수료_받을_주소를_여기에_입력하세요

# RLUSD 스테이블코인 설정
# 테스트넷 RLUSD 발행자 주소
RLUSD_ISSUER=rMxCKbEDwqr76QuheSUMdEGf4B9xJ8m5De

# RLUSD 통화 코드 (표준 3자리)
RLUSD_CURRENCY=USD
