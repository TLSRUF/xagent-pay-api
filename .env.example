# XAgent Pay API 환경변수 설정 예시
# 이 파일을 복사해서 .env 파일을 생성하고 실제 값을 입력하세요

# XRPL 테스트넷 계정 정보
SENDER_ADDRESS=테스트넷_XRP_주소를_여기에_입력하세요
SENDER_SECRET=시크릿_키를_여기에_입력하세요

# 수수료 수신 계정 (일반적으로 발신자와 동일)
FEE_ACCOUNT=수수료_받을_주소를_여기에_입력하세요

# XRPL 테스트넷 노드 주소
XRPL_NODE=wss://s.altnet.rippletest.net:51233

# API Keys (콤마로 구분, 레거시 방식)
# 서버 최초 기동 시 keys/api_keys.json에 tier=pro(무제한)로 자동 마이그레이션됩니다.
# 신규 키 발급은 POST /admin/keys 엔드포인트를 사용하세요.
# 예: API_KEYS=key1,key2,key3
API_KEYS=test_key_123456,prod_key_789012,demo_key_345678

# 관리자 키 (API 키 발급/조회/폐기용, X-Admin-Key 헤더)
# 설정하지 않으면 /admin/keys 관련 엔드포인트가 비활성화됩니다.
ADMIN_API_KEY=강력한_관리자_키를_여기에_입력하세요

# 지갑 시크릿(seed) 암호화 마스터 키 (Fernet 키, 절대 코드에 하드코딩하지 마세요)
# 생성 방법: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 설정하지 않으면 API 키 발급 시 전용 지갑 생성이 비활성화되고 플랫폼 공용 지갑을 사용합니다
# (지갑 시크릿을 암호화 없이 저장하지 않기 위한 안전장치입니다).
# 한 번 설정한 뒤 값을 바꾸면 기존에 암호화된 지갑 시크릿을 복호화할 수 없게 되니
# 절대 분실하지 말고 별도로 안전하게 백업하세요.
SECRET_ENCRYPTION_KEY=

# Rate Limiting - Free tier 월 최대 요청 수 (Pro/Enterprise는 무제한)
FREE_MONTHLY_LIMIT=100

# 결제 수수료율 (가격 정책 기준값, tier별 기본값 — 필요 시에만 조정)
# Pro의 $49/월 구독료는 이 API가 아닌 별도 SaaS 과금 레이어에서 처리합니다.
# Enterprise 커스텀 협의 요율은 키 발급 시 fee_rate 파라미터로 개별 지정하세요.
FREE_FEE_RATE=0.01
PRO_FEE_RATE=0.0015
ENTERPRISE_FEE_RATE=0.0015

# x402 결제 설정
# JWT 서명 키 (프로덕션에서는 반드시 변경하세요)
JWT_SECRET=강력한_비밀_키를_여기에_입력하세요

# x402 결제 금액 (XRP 단위)
X402_PAYMENT_AMOUNT=0.1

# x402 수수료 수신 주소
X402_FEE_ADDRESS=수수료_받을_주소를_여기에_입력하세요

# RLUSD 스테이블코인 설정
# 테스트넷 RLUSD 발행자 주소
RLUSD_ISSUER=rMxCKbEDwqr76QuheSUMdEGf4B9xJ8m5De

# RLUSD 통화 코드 (표준 3자리)
RLUSD_CURRENCY=USD
